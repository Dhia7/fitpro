# ==========================================
# Supabase Configuration
# ==========================================
# Get these from your Supabase dashboard: https://app.supabase.com
# Project Settings > API > Project URL & anon/public key

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ==========================================
# Email Service Configuration (Resend)
# ==========================================
# 1. Sign up at https://resend.com
# 2. Get your API key from the dashboard
# 3. Verify your domain in Resend dashboard
# 4. Use a verified domain email address

VITE_RESEND_API_KEY=re_your_resend_api_key_here

# ==========================================
# Supabase Edge Function Secrets
# ==========================================
# These are set in Supabase Dashboard: https://app.supabase.com
# Project Settings > Edge Functions > Secrets
# 
# Run these commands with Supabase CLI:
# supabase secrets set RESEND_API_KEY=re_your_resend_api_key_here
# supabase secrets set FROM_EMAIL="FitPlan Pro <noreply@yourdomain.com>"
# supabase secrets set APP_NAME="FitPlan Pro"

# ==========================================
# Optional: Email Service Provider
# ==========================================
# Default is 'supabase'. Other options: 'mailchimp', 'convertkit', 'webhook', 'localStorage'
# VITE_EMAIL_SERVICE=supabase

# ==========================================
# Optional: Other Email Services
# ==========================================
# Only needed if using Mailchimp or ConvertKit
# VITE_CONVERTKIT_API_KEY=your_convertkit_api_key
# VITE_CONVERTKIT_FORM_ID=your_convertkit_form_id
# VITE_MAILCHIMP_API_KEY=your_mailchimp_api_key
# VITE_MAILCHIMP_LIST_ID=your_mailchimp_list_id
